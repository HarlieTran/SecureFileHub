@{
    ViewData["Title"] = "Delete Account";
}

<div class="container mt-4" style="max-width: 480px;">
    <h2 class="text-danger">Delete My Account</h2>
    <div class="alert alert-warning">
        <strong>Warning:</strong> This action is permanent. Your account, all uploaded files, and all share links will be deleted immediately and cannot be recovered.
    </div>

    <div asp-validation-summary="All" class="text-danger mb-3"></div>

    <form method="post">
        @Html.AntiForgeryToken()
        <div class="mb-3">
            <label class="form-label">Confirm your password to proceed</label>
            <input type="password" name="password" class="form-control" required autofocus />
        </div>
        <button type="submit" class="btn btn-danger"
                onclick="return confirm('Are you absolutely sure? This cannot be undone.');">
            Permanently Delete My Account
        </button>
        <a href="/Files" class="btn btn-secondary ms-2">Cancel</a>
    </form>
</div>
