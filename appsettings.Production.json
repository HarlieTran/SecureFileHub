{
  "Logging": {
    "LogLevel": {
      // Production: suppress verbose framework noise; only log warnings and above.
      // Detailed logs go to server-side log files, never to the browser.
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AppSettings": {
    // Shorter session timeout in production to reduce the window for session hijacking.
    "SessionTimeoutMinutes": 20,
    // Stricter lockout policy in production.
    "MaxLoginAttempts": 5,
    "LockoutDurationMinutes": 15
  }
  // Production-only secrets (ENCRYPTION_KEY, connection string) are supplied
  // via environment variables or a secrets manager — never in this file.
}
